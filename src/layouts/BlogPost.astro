---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { repoLink?: string };

const { title, description, pubDate, updatedDate, heroImage, repoLink } =
	Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.container {
				display: flex;
				flex-direction: row;
			}
			.left-column {
				display: flex;
				flex: 0.25;
				flex-direction: row;
			}
			.left-column .left {
				display: flex;
				flex: 1;
			}
			.left-column .right {
				display: flex;
				flex: 1;
				flex-direction: column;
			}
			.left-column .right .row-top {
				flex: 1;
				border-bottom-left-radius: var(--border-radius);
				border-left: var(--border-width) solid var(--border-color);
				border-bottom: var(--border-width) solid var(--border-color);
			}
			.left-column .right .row-bottom {
				height: 3em
			}
			.center-column {
				display: flex;
				flex: 0.5;
				flex-direction: column;
			}
			.right-column {
				display: flex;
				flex: 0.25;
				flex-direction: row;
			}
			.right-column .left {
				display: flex;
				flex: 1;
				flex-direction: column;
			}
			.right-column .left .row-top {
				flex: 0.55;
			}
			.right-column .left .row-middle {
				flex: 0.45;
				border-top-right-radius: var(--border-radius);
				border-bottom-right-radius: var(--border-radius);
				border-top: var(--border-width) solid var(--border-color);
				border-right: var(--border-width) solid var(--border-color);
				border-bottom: var(--border-width) solid var(--border-color);			
			}
			.right-column .left .row-bottom {
				height: 3em;
			}
			.right-column .right {
				display: flex;
				flex: 1;
			}
			.hero-image {
				margin: 0;
				max-width: 100%;						
			}
			.hero-image img {
				display: block;
				box-sizing: border-box;
				width: 100%;
				height: auto;
				max-height: 640px;	
				margin: 2em 0 0 0;
				box-shadow: var(--box-shadow);
			}
			.title {
				margin-top: 2em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
				font-family: var(--font-orbitron);
				border-radius: var(--border-radius);
				border: var(--border-width) solid var(--border-color);
				box-shadow: var(--box-shadow);
			}
			.title h1 {
				margin: 0;
				font-size: clamp(1.5rem, 4vw + 1rem, 2.5rem);
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--ink);
			}
			.last-updated-on {
				font-style: italic;
			}
			.prose {
				padding: 1em;
				margin-bottom: 3em;
			}
			.repo-link-wrapper {
				text-align: center;
			}
			.repo-link {
				display: inline-block;
				margin-top: 2em;
				padding: 0.6em 1.2em;
				border-radius: var(--border-radius);
				background-color: #ff3445;
				color: #fff;
				font-weight: 600;
				text-decoration: none;
				transition: background-color 0.2s ease;
			}
			.repo-link:hover {
				background-color: #c1121f;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="container">
					<div class="left-column">
						<div class="left"></div>
						<div class="right">
							<div class="row-top"></div>
							<div class="row-bottom"></div>
						</div>
					</div>
					<div class="center-column">
						<div class="hero-image">
							{heroImage && <Image src={heroImage} alt="" />}
						</div>
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on{' '}
											<FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
						</div>
					</div>
					<div class="right-column">
						<div class="left">
							<div class="row-top"></div>
							<div class="row-middle"></div>
							<div class="row-bottom"></div>
						</div>
						<div class="right"></div>
					</div>
				</div>
				<div class="prose">
					<slot />
					{
						repoLink && (
							<div class="repo-link-wrapper">
								<a
									class="repo-link"
									href={repoLink}
									target="_blank"
									rel="noopener noreferrer"
								>
									Link to GitHub Repo
								</a>
							</div>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
