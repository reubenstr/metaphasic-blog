---
import { FOOTER_QUOTE } from '../consts';
import TopVerticalLine from '../components/TopVerticalLine.astro';

const today = new Date();
---

<footer>
	<div class="top-row">
		<div class="top-item">		
		</div>
		<div class="top-item center">			
		</div>
		<div class="top-item">
			<TopVerticalLine height="1em" />
			<a class="icon-container" href="https://github.com/reubenstr" target="_blank">
				<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
				</svg>
			</a>
		</div>
	</div>
	<div class="info-container">
		<p class="quote">{FOOTER_QUOTE}</p>
		&copy; {today.getFullYear()} Metaphasic Labs. All rights reserved.
	</div>
</footer>
<style>
	footer {
		flex-direction: column;
		padding: 0em 1em 2em 1em;
		background: var(--bg);
		color: var(--fg);
		text-align: center;
		font-family: var(--font-orbitron);
		border-top: var(--border-width) solid var(--border-color);
	}
	.top-row {
		display: flex;
		align-items: center;		
	}
	.top-item {
		display: flex;
		flex: 1;
		flex-direction: column;
		align-items: center;		
	}
	.top-item.center {
		flex: none;
		align-self: stretch;
		width: var(--border-width);
		background: var(--border-color);
	}
	.icon-container {
		display: inline-flex;
		padding: 0.3em;
		margin-bottom: 1em;
		border-radius: var(--border-radius);
		border: var(--border-width) solid var(--border-color);
		color: inherit;
		transition: background-color 0.2s, color 0.2s;
	}
	.icon-container:hover {
		background-color: var(--fg);
		color: var(--bg);
	}
	.info-container {
		display: inline-block;
		padding: 1em 2em;
		border-radius: var(--border-radius);
		border: var(--border-width) solid var(--border-color);
		box-shadow: var(--box-shadow);
	}
	.quote {
		margin: 0 0 1em 0;
		font-family: var(--font-orbitron);
	}
</style>
