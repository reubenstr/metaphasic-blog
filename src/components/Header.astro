---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive = (...hrefs: string[]) =>
	hrefs.some(
		(href) => href === pathname || href === '/' + (subpath?.[0] || ''),
	);
---

<header>
	<ThemeToggle />
	<nav>
		<h1 class="revolve-bg revolve-text no-border-dark">
			<a href="/">{SITE_TITLE}</a>
		</h1>
		<div class="link-row">
			<div class="v-line-spacer left"></div>
			<div class="v-line"></div>
			<div class="v-line-spacer"></div>
			<div class="internal-links">
				<div class="nav-item">
					<a href="/blog" class:list={{ active: isActive('/', '/blog') }}
						>Blog</a
					>
					<div class="tick-row"></div>
				</div>
				<div class="nav-item">
					<a href="/about" class:list={{ active: isActive('/about') }}>About</a>
					<div class="tick-row"></div>
				</div>
				<div class="nav-item">
					<a href="/contact" class:list={{ active: isActive('/contact') }}
						>Contact</a
					>
					<div class="tick-row"></div>
				</div>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		position: relative;
		margin: 0;
		padding: 1em 1em 0em 1em;
		background: var(--bg);
	}
	h1 {
		margin: 0;
		font-size: 2em;
		font-family: var(--font-orbitron);
		border-radius: var(--border-radius);
		box-shadow: var(--box-shadow);
	}

	h1 a,
	h1 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		flex-direction: column;
		border-bottom: var(--border-width) solid var(--border-color);
		font-family: var(--font-orbitron);
		font-weight: 700;
	}
	nav h1 {
		align-self: flex-start;
	}
	nav .link-row {
		display: flex;
		flex-direction: row;
	}
	nav .v-line-spacer {
		flex: 1;
	}
	nav .v-line-spacer.left {
		flex: 1;
		max-width: 9.38em;
	}
	nav .v-line {
		flex: 1;
		border-left: var(--border-width) solid var(--border-color);
	}
	nav .internal-links {
		display: flex;
		gap: 0.5em;
		align-self: flex-end;
		margin-top: 0.5em;
	}
	.nav-item {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.tick-row {
		width: 100%;
		height: 0.5em;
		width: var(--border-width);
		background: var(--border-color);
	}
	nav a {
		display: inline-block;
		padding: 0.1em 0.5em;
		color: var(--fg);
		border-radius: var(--border-radius);
		text-decoration: none;
		border: var(--border-width) solid var(--border-color);
		transition: background-color 0.2s, color 0.2s;
	}
	nav a:hover {
		color: var(--bg);
		background-color: var(--fg);
	}
	nav a.active {
		color: var(--bg);
		background-color: var(--fg);
		border-color: var(--border-color);
	}
</style>
